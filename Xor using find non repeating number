public class FindUniqueNumber {
    public static int findSingle(int[] nums) {
        int result = 0;
        for (int num : nums) {
            result ^= num; 
        }
        return result;
    }

    public static void main(String[] args) {
        int[] nums = {2, 2, 1, 4, 4};
        System.out.println("Unique element: " + findSingle(nums)); 
    }
}
