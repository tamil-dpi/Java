import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int N = sc.nextInt();
        sc.close();

        int count = 0;
        int sum = 0;
        int coin = 1;

        while (sum < N) {
            count++;
            sum += coin;
            coin = sum + 1;
        }

        System.out.println(count);
    }
}
