import java.util.Scanner;
public class Main
{
    public static int step(int n){
        if(n==0||n==1)return 1;return step(n-1)+step(n-2);
    }
	public static void main(String[] args) {
	   Scanner sc=new Scanner(System.in);
	   int a=sc.nextInt();
	   int b=step(a);
	   System.out.print(b);
	}
}
